{
  "name": "@sentinel/api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "predev": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "prestart": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "tsc -p tsconfig.json && node dist/tests/smoke.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "tsx src/tests/seed.ts"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.12.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@prisma/client": "^6.0.1",
    "@sentinel/middleware": "0.1.0",
    "@sentinel/policies": "0.1.0",
    "@sentinel/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "genkit": "^1.12.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "openai": "^4.104.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.1",
    "prisma": "^6.0.1",
    "tsx": "^4.19.2"
  }
}
