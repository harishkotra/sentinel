PORT=8080
DATABASE_URL="file:./prisma/dev.db"
POLICY_FILE="../../packages/policies/default-policy.yaml"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"

# Provider selection: google | featherless | lmstudio
SENTINEL_MODEL_PROVIDER=google

# Google provider
GENKIT_MODEL="googleai/gemini-2.5-flash"
GOOGLE_API_KEY=""

# Featherless (OpenAI-compatible)
FEATHERLESS_BASE_URL="https://api.featherless.ai/v1"
FEATHERLESS_API_KEY=""
FEATHERLESS_MODEL="meta-llama/Meta-Llama-3.1-8B-Instruct"

# LM Studio local (OpenAI-compatible)
LMSTUDIO_BASE_URL="http://127.0.0.1:1234/v1"
LMSTUDIO_API_KEY="lm-studio"
LMSTUDIO_MODEL="local-model"

# Telegram-only human approvals
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
SENTINEL_PUBLIC_BASE_URL="http://localhost:8080"
