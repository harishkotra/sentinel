{
  "name": "sentinel",
  "version": "0.1.0",
  "private": true,
  "author": "Harish Kotra",
  "description": "Sentinel: AI Agent Jailbreak Firewall for Genkit",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @sentinel/api run dev",
    "dev:web": "npm --workspace @sentinel/web run dev",
    "build": "npm-run-all build:packages build:api build:web",
    "build:packages": "npm --workspace @sentinel/shared run build && npm --workspace @sentinel/detection-engine run build && npm --workspace @sentinel/policies run build && npm --workspace @sentinel/middleware run build",
    "build:api": "npm --workspace @sentinel/api run build",
    "build:web": "npm --workspace @sentinel/web run build",
    "lint": "npm-run-all lint:*",
    "lint:api": "npm --workspace @sentinel/api run lint",
    "lint:web": "npm --workspace @sentinel/web run lint",
    "test": "npm --workspace @sentinel/api run test",
    "db:migrate": "npm --workspace @sentinel/api run db:migrate",
    "db:seed": "npm --workspace @sentinel/api run db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.2"
  }
}
